# Copy to `.env` (or `.env.local`) and fill in real values. Do not commit `.env`.

# Database (Prisma reads `qbrix_DATABASE_URL`; app may also use `DATABASE_URL`)
DATABASE_URL="postgresql://user:password@localhost:5432/your_database"
qbrix_DATABASE_URL="postgresql://user:password@localhost:5432/your_database"

# NextAuth
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3001"

# Chatbot / OpenAI (required for LLM + RAG embeddings)
OPENAI_API_KEY="sk-..."
# Alternates also supported: OPEN_AI_API_KEY, OPENAI_KEY, OPEN_AI_KEY
OPENAI_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Optional
# OPENAI_BASE_URL=https://api.openai.com/v1
# CHATBOT_LLM_DISABLED=false
# CHATBOT_SYSTEM_PROMPT=
